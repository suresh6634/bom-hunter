{
  "name": "pecko-bom-converter",
  "version": "1.0.1",
  "private": true,
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "start": "NODE_ENV=production node server/index.js",
    "db:push": "node_modules/.bin/prisma db push --schema=prisma/schema.prisma",
    "db:generate": "node_modules/.bin/prisma generate --schema=prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "setup": "npm run db:push && npm run db:generate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "5.22.0"
  },
  "overrides": {
    "zod": "3"
  }
}
